{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "orgnz",
  "version": "0.1.0",
  "identifier": "com.yourname.orgnz",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081"
  },
  "app": {
    "windows": [
      {
        "title": "orgnz",
        "width": 1180,
        "height": 800,
        "minWidth": 860,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "notification": {}
  }
}
