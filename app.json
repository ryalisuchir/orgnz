{
  "expo": {
    "name": "orgnz",
    "slug": "orgnz",
    "scheme": "orgnz",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0E12"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.orgnz",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to unlock orgnz."
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#0B0B0E"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6C63FF"
        }
      ]
    ],
    "extra": {
      "supabaseUrl": "SUPABASE_URL_SET_IN_ENV",
      "supabaseAnonKey": "SUPABASE_ANON_KEY_SET_IN_ENV",
      "router": { "origin": false }
    }
  }
}